# ═══════════════════════════════════════════════════════════
# VAZHIKATTI — Environment Variables
# ═══════════════════════════════════════════════════════════
# Copy this file to .env and fill in the values.
# For production, add these to Vercel → Settings → Environment Variables.
# ═══════════════════════════════════════════════════════════

# ─── SUPABASE (Required) ───
VITE_SUPABASE_URL=https://jahtuebykoledutqhzfx.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_key_here
VITE_SUPABASE_PROJECT_ID=jahtuebykoledutqhzfx

# ─── SUPABASE SERVER (Required for Admin Panel) ───
# Get from: Supabase Dashboard → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_URL=https://jahtuebykoledutqhzfx.supabase.co

# ─── ADMIN PANEL (Optional — defaults exist) ───
VITE_ADMIN_PASSWORD=your_admin_password
VITE_ADMIN_EMAIL=admin@vazhikatti.app
VITE_ADMIN_SUPABASE_PASS=your_admin_supabase_password
ADMIN_PASSWORD=your_admin_password

# ─── EMAIL (Required for registration emails) ───
# Get from: resend.com → API Keys
RESEND_API_KEY=your_resend_api_key_here

# ─── SMS (Optional — for tracker reminders) ───
# Get from: msg91.com → API Keys
MSG91_AUTH_KEY=your_msg91_auth_key
MSG91_TEMPLATE_ID=your_msg91_template_id

# ─── ANALYTICS (Optional) ───
# Get from: Google Analytics → Admin → Data Streams → Measurement ID
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
